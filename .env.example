# ===== LLM: DeepSeek (OpenAI 兼容协议) =====
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== Embedding: 通义千问 DashScope (OpenAI 兼容端点) =====
DASHSCOPE_API_KEY=sk-replace-me
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBED_MODEL=text-embedding-v3

# ===== Chroma 向量库 =====
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=enterprise_docs

# ===== 检索/生成参数 =====
RETRIEVE_TOP_K=5
MAX_REFLECT_ROUNDS=2

# ===== LangSmith 可观测性（可选，留空则关闭）=====
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=enterprise-doc-agent
